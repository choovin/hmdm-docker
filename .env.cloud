# Headwind MDM 云服务器部署配置
# 域名: dmd.runnode.cn

# 数据库配置
SQL_BASE=hmdm
SQL_USER=hmdm
SQL_PASS=YourStrongPassword123

# 管理员邮箱（用于证书通知等）
ADMIN_EMAIL=admin@dmd.runnode.cn

# 你的域名
BASE_DOMAIN=dmd.runnode.cn

# 如果你的服务器有内网 IP（可选）
# LOCAL_IP=172.31.x.x

# 首次启动设为 true，之后改为 false
FORCE_RECONFIGURE=true

# 生产环境使用 HTTPS
PROTOCOL=https

# 共享密钥（生产环境必须修改！）
SHARED_SECRET=changeme-C3z9vi54

# HMDM 版本配置
HMDM_VARIANT=os
DOWNLOAD_CREDENTIALS=
HMDM_URL=https://h-mdm.com/files/hmdm-5.38.1-os.war
CLIENT_VERSION=6.31
